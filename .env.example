# ════════════════════════════════════════════════════════════
# cr-agent 环境变量配置示例
# 复制为 .env 并填入实际值后启动
# 环境变量统一前缀 CR_AGENT_（自动添加，这里只写变量名）
# ════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════
# 🚨 生产必填（部署前必须配置）
# ════════════════════════════════════════════════════════════

# ── LLM Chat 客户端（必填）──
# OpenAI / 兼容 API 的 key 和 base URL
CR_AGENT_CHAT_API_KEY=sk-your-api-key-here
CR_AGENT_CHAT_BASE_URL=https://api.openai.com/v1
CR_AGENT_CHAT_MODEL=gpt-4o-mini

# ── API / MCP 鉴权（JWT）──
# ⚠️ 生产必须启用并设置强密钥！
# 如何生成 JWT_SECRET：openssl rand -hex 32
CR_AGENT_API_AUTH_REQUIRED=False
CR_AGENT_JWT_SECRET=change-me-production-secret-min-32-bytes
CR_AGENT_API_KEY=your-admin-api-key
CR_AGENT_JWT_EXPIRE_MINUTES=30

# ── 数据库（开发默认 SQLite，生产建议 PostgreSQL）──
# Railway Postgres 会自动注入 DATABASE_URL
CR_AGENT_DATABASE_URL=sqlite+aiosqlite:///./data/cr_agent.db
# CR_AGENT_DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# ════════════════════════════════════════════════════════════
# 🔧 可选配置（不填则使用默认值）
# ════════════════════════════════════════════════════════════

# ── 多模型支持（可选，不填则用 CHAT_MODEL）──
# 为不同角色指定不同模型（降本 / 提质策略）
# 示例：decompose + aggregate 用便宜模型，worker 用强模型，judge 用最强模型
# CR_AGENT_DECOMPOSE_MODEL=gpt-4o-mini
# CR_AGENT_WORKER_QUALITY_MODEL=gpt-4o
# CR_AGENT_WORKER_SECURITY_MODEL=gpt-4o
# CR_AGENT_WORKER_PERFORMANCE_MODEL=gpt-4o
# CR_AGENT_WORKER_STRUCTURE_MODEL=gpt-4o
# CR_AGENT_JUDGE_MODEL=gpt-4o

# ── LLM 调用超时（秒）──
# 默认 120s，代码分析耗时较长可调大
# CR_AGENT_LLM_TIMEOUT=120.0

# ── 置信度阈值（0.0-1.0）──
# 过滤低置信度 finding，0.0 = 不过滤
# CR_AGENT_DEFAULT_CONFIDENCE_THRESHOLD=0.0

# ── Langfuse 链路追踪（可选）──
# 不配置则静默降级为 NoOp
# CR_AGENT_LANGFUSE_PUBLIC_KEY=
# CR_AGENT_LANGFUSE_SECRET_KEY=
# CR_AGENT_LANGFUSE_HOST=http://localhost:3000

# ── Webhook 安全（GitHub Webhook 签名验证）──
# 生产必须设为 True 并配置 secret
# CR_AGENT_WEBHOOK_SECRET_REQUIRED=False
# CR_AGENT_GITHUB_WEBHOOK_SECRET=your-webhook-secret

# GitHub API token（PR 获取需要）
# CR_AGENT_GITHUB_TOKEN=ghp_your-token

# ── 日志级别 ──
# CR_AGENT_LOG_LEVEL=INFO

# ── 环境标识（dev / test / prod）──
# 控制加载哪个 .env 文件（.env.dev / .env.test / .env.prod）
# APP_ENV=dev
